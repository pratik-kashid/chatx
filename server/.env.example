# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/chatx

# JWT Secret
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Frontend URL(s) allowed by CORS. For multiple origins, use comma-separated values.
FRONTEND_URL=http://localhost:5173
